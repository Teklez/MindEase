# Database (backend)
DATABASE_URL=postgresql+asyncpg://mindease:mindease_dev@localhost:5432/mindease

# Auth & API
SECRET_KEY=your-secret-key-change-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
FRONTEND_URL=http://localhost:3000

# Redis (optional, for sessions/cache)
REDIS_URL=redis://localhost:6379/0

# AI service & backend — Gemini (Amharic chat translation + voice avatar Live sessions)
# Used by both ai-service and backend containers. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Frontend (build-time / client)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Optional: WebSocket URL (defaults to API URL with ws/wss). Set if API is proxied but WS is not.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
